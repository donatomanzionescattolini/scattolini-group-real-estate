# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
# Create a new project and web app to get these credentials

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Firebase Analytics
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AWS S3 Configuration
# Get these values from your AWS IAM Console
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your_aws_access_key_id
VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional: only needed for temporary/STS credentials
VITE_AWS_SESSION_TOKEN=your_aws_session_token
VITE_S3_BUCKET=your_s3_bucket_name
