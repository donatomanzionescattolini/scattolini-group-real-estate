# ─── Contact / lead forms (Web3Forms) ───────────────────────────────────────
#
# All site forms (contact, market-report, newsletter, exit-intent modal) POST
# directly to Web3Forms, which emails the submission to the inbox registered to
# this access key. Create a free key at https://web3forms.com using the address
# information@scattolinigroup.com — submissions then arrive straight in that inbox with
# no mail app involved. This key is safe to expose in the client bundle.
#
# Set it in Vercel (Project → Settings → Environment Variables) for production,
# and in a local .env for `npm run dev`.
VITE_WEB3FORMS_KEY=your_web3forms_access_key

# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
# Create a new project and web app to get these credentials

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Firebase Analytics
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
#
# SECURITY MODEL (see api/s3.js + src/services/s3.ts):
#   • PRODUCTION (Vercel): set the SERVER-SIDE vars below WITHOUT the VITE_
#     prefix. They stay in the serverless function and are NEVER bundled into
#     the client. The browser uploads via short-lived presigned URLs.
#     Do NOT set VITE_AWS_ACCESS_KEY_ID / VITE_AWS_SECRET_ACCESS_KEY in prod —
#     anything VITE_* prefixed is shipped to the browser.
#   • LOCAL DEV (`npm run dev`): the VITE_AWS_* vars let the editor talk to S3
#     directly without running `vercel dev`. This path is dev-only and is
#     stripped from production builds.
#
# Server-side (Vercel Project → Settings → Environment Variables):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=        # only for temporary/STS credentials
S3_BUCKET=your_s3_bucket_name

# Public (safe to expose) — used only to build asset URLs:
VITE_S3_BUCKET=your_s3_bucket_name

# Local-dev convenience only (DO NOT set these in production):
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your_aws_access_key_id
VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# VITE_AWS_SESSION_TOKEN=
